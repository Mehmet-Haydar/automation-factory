{
  "_schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "block": {
    "name": "FB_AnalogScale",
    "version": "1.0.0",
    "type": "FB",
    "domain": "process",
    "device_type": "AnalogScale",
    "platform": "S7_1500_TIA_V18+",
    "source": "Factory",
    "lifecycle": "DRAFT",
    "description": "Analog signal scaling and validation. Raw ADC → engineering units, range check, clamp, wire-break detection."
  },
  "interface": {
    "inputs": [
      {
        "name": "in_bEnable",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bReset",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_iRawValue",
        "iec_type": "Int",
        "default": 0,
        "required": true,
        "description": "Raw ADC value (e.g. 0-27648 for 4-20mA)"
      },
      {
        "name": "in_rRawMin",
        "iec_type": "Real",
        "default": 0.0,
        "required": true
      },
      {
        "name": "in_rRawMax",
        "iec_type": "Real",
        "default": 27648.0,
        "required": true
      },
      {
        "name": "in_rEngMin",
        "iec_type": "Real",
        "default": 0.0,
        "required": true
      },
      {
        "name": "in_rEngMax",
        "iec_type": "Real",
        "default": 100.0,
        "required": true
      },
      {
        "name": "in_rHiHiLimit",
        "iec_type": "Real",
        "default": 95.0,
        "required": true
      },
      {
        "name": "in_rHiLimit",
        "iec_type": "Real",
        "default": 90.0,
        "required": true
      },
      {
        "name": "in_rLoLimit",
        "iec_type": "Real",
        "default": 10.0,
        "required": true
      },
      {
        "name": "in_rLoLoLimit",
        "iec_type": "Real",
        "default": 5.0,
        "required": true
      }
    ],
    "outputs": [
      {
        "name": "out_rEngValue",
        "iec_type": "Real",
        "default": 0.0,
        "required": true
      },
      {
        "name": "out_bHiHi",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bHi",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bLo",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bLoLo",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bWireBreak",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bError",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_wErrorCode",
        "iec_type": "Word",
        "default": "16#0000",
        "required": true
      },
      {
        "name": "out_nState",
        "iec_type": "Int",
        "default": 0,
        "required": true
      }
    ],
    "in_out": [],
    "static_vars": [
      {
        "name": "s_bResetEdgeMem",
        "iec_type": "Bool"
      },
      {
        "name": "s_bResetTrig",
        "iec_type": "Bool"
      },
      {
        "name": "s_nStep",
        "iec_type": "Int"
      }
    ]
  },
  "constraints": {
    "mandatory_regions": [
      "01_INPUT_VALIDATION",
      "02_STATE_MACHINE",
      "03_OUTPUT_LOGIC",
      "04_DIAGNOSTICS"
    ],
    "mandatory_behaviors": [
      {
        "id": "B-AS-001",
        "description": "Reset rising edge",
        "check_pattern": "s_bResetTrig\\s*:=\\s*.*in_bReset.*AND\\s*NOT.*s_bResetEdgeMem",
        "severity": "MUST"
      },
      {
        "id": "B-AS-002",
        "description": "Linear scaling applied (raw→engineering)",
        "check_pattern": "in_rRawMin|in_rRawMax|in_rEngMin|in_rEngMax|scale|Scale",
        "severity": "MUST"
      },
      {
        "id": "B-AS-003",
        "description": "Wire-break detection",
        "check_pattern": "out_bWireBreak|WireBreak|wire_break",
        "severity": "MUST"
      },
      {
        "id": "B-AS-004",
        "description": "HiHi limit check",
        "check_pattern": "in_rHiHiLimit|out_bHiHi|HiHi",
        "severity": "MUST"
      },
      {
        "id": "B-AS-005",
        "description": "Error code 16#0001 present",
        "check_pattern": "16#0001",
        "severity": "MUST"
      },
      {
        "id": "B-AS-006",
        "description": "FB name is FB_AnalogScale",
        "check_pattern": "FUNCTION_BLOCK\\s+\"?FB_AnalogScale\"?",
        "severity": "MUST"
      },
      {
        "id": "B-AS-007",
        "description": "Optimized Access declared",
        "check_pattern": "S7_Optimized_Access\\s*:=\\s*'TRUE'",
        "severity": "MUST"
      }
    ],
    "forbidden_patterns": [
      "CURRENT_TIME\\(\\)",
      "GET_SYSTIME\\(\\)"
    ],
    "error_codes": [
      {
        "hex": "16#0001",
        "meaning": "Wire break detected (raw value below wire-break threshold)"
      },
      {
        "hex": "16#0002",
        "meaning": "Raw value out of expected range (overrange)"
      }
    ]
  },
  "gate": {
    "checks": [
      {
        "id": "G-01",
        "type": "structural",
        "description": "Structural balance",
        "required": true
      },
      {
        "id": "G-02",
        "type": "contract_interface",
        "description": "Required ports",
        "required": true
      },
      {
        "id": "G-03",
        "type": "contract_behavior",
        "description": "MUST behaviors",
        "required": true
      },
      {
        "id": "G-04",
        "type": "contract_error_codes",
        "description": "Error codes in SCL",
        "required": true
      },
      {
        "id": "G-05",
        "type": "forbidden_pattern",
        "description": "No proprietary calls",
        "required": true
      },
      {
        "id": "G-06",
        "type": "plcrex",
        "description": "PLCreX optional",
        "required": false
      }
    ]
  },
  "prompt_binding": {
    "file": "04_AI_PROMPTS/code_gen/process/PROMPT_PROCESS_ANALOG_SCALING.md",
    "version": "1.0.0",
    "last_synced": "2026-05-30"
  },
  "duplicate_detection": {
    "alternatives": [],
    "note": "Use for 4-20mA or 0-10V analog inputs requiring engineering unit conversion + limit alarms."
  },
  "meta": {
    "source": "factory",
    "license": "MIT",
    "safety_class": "STANDARD",
    "target_platform": "TIA Portal V18+",
    "compatible_tia": [
      "V18",
      "V19"
    ]
  },
  "behaviors": [
    {
      "id": "WIRE_BREAK",
      "given": "in_iRawValue < (in_rRawMin - 10% of span)",
      "when": "any scan",
      "then": "out_bWireBreak=TRUE AND out_bError=TRUE AND out_wErrorCode=16#0001"
    },
    {
      "id": "LINEAR_SCALE",
      "given": "raw value within valid range",
      "when": "in_bEnable=TRUE",
      "then": "out_rEngValue = linear interpolation to engineering units using in_rRawMin/Max and in_rEngMin/Max"
    },
    {
      "id": "HIHI_ALARM",
      "given": "out_rEngValue >= in_rHiHiLimit",
      "when": "any scan",
      "then": "out_bHiHi=TRUE"
    }
  ],
  "acceptance": {
    "contract_check": true,
    "compile_check": true,
    "sim_test": true,
    "human_signoff": true
  }
}