{
  "_schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "block": {
    "name": "FB_Motor_StarDelta",
    "version": "1.0.0",
    "type": "FB",
    "domain": "motor",
    "device_type": "StarDelta",
    "platform": "S7_1500_TIA_V18+",
    "source": "Factory",
    "lifecycle": "DRAFT",
    "description": "Star-Delta motor starter. Three contactors (main/star/delta), run feedback, overload, transition timing."
  },
  "interface": {
