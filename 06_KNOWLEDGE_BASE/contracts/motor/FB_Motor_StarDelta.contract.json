      {
        "name": "s_bResetEdgeMem",
        "iec_type": "Bool"
      },
      {
        "name": "s_bResetTrig",
        "iec_type": "Bool"
      },
      {
        "name": "s_nStep",
        "iec_type": "Int"
      },
      {
        "name": "s_tonStarDur",
        "iec_type": "TON"
      },
      {
        "name": "s_tonDeadTime",
        "iec_type": "TON"
      },
      {
        "name": "s_tonStartTO",
        "iec_type": "TON"
      }
    ]
  },
  "constraints": {
    "mandatory_regions": [
      "01_INPUT_VALIDATION",
      "02_STATE_MACHINE",
      "03_OUTPUT_LOGIC",
      "04_DIAGNOSTICS"
    ],
    "mandatory_behaviors": [
      {
        "id": "B-SD-001",
        "description": "Reset rising edge",
        "check_pattern": "s_bResetTrig\\s*:=\\s*.*in_bReset.*AND\\s*NOT.*s_bResetEdgeMem",
        "severity": "MUST"
      },
      {
        "id": "B-SD-002",
        "description": "Star-Duration timer present",
        "check_pattern": "s_tonStarDur",
        "severity": "MUST"
      },
      {
        "id": "B-SD-003",
        "description": "Dead-time (star-off to delta-on) timer present",
        "check_pattern": "s_tonDeadTime",
        "severity": "MUST"
      },
      {
        "id": "B-SD-004",
        "description": "STAR and DELTA outputs mutually exclusive (never both TRUE)",
        "check_pattern": "out_bStar.*AND.*out_bDelta|interlock|NOT.*out_bDelta|NOT.*out_bStar",
        "severity": "MUST"
      },
      {
        "id": "B-SD-005",
        "description": "Error code 16#0001 present",
        "check_pattern": "16#0001",
        "severity": "MUST"
      },
      {
        "id": "B-SD-006",
        "description": "Error code 16#0003 (overload) present",
        "check_pattern": "16#0003",
        "severity": "MUST"
      },
      {
        "id": "B-SD-007",
        "description": "Error code 16#0010 (STAR+DELTA overlap) present",
        "check_pattern": "16#0010",
        "severity": "MUST"
      },
      {
        "id": "B-SD-008",
        "description": "FB name is FB_Motor_StarDelta",
        "check_pattern": "FUNCTION_BLOCK\\s+\"?FB_Motor_StarDelta\"?",
        "severity": "MUST"
      },
      {
        "id": "B-SD-009",
        "description": "Optimized Access declared",
        "check_pattern": "S7_Optimized_Access\\s*:=\\s*'TRUE'",
        "severity": "MUST"
      }
    ],
    "forbidden_patterns": [
      "CURRENT_TIME\\(\\)",
      "GET_SYSTIME\\(\\)",
      "RUNTIME\\s*\\("
    ],
    "error_codes": [
      {
        "hex": "16#0001",
        "meaning": "Main contactor no run feedback within timeout"
      },
      {
        "hex": "16#0003",
        "meaning": "Motor overload triggered"
      },
      {
        "hex": "16#0010",
        "meaning": "STAR and DELTA feedback both active simultaneously"
      },
      {
        "hex": "16#0011",
        "meaning": "Transition timeout (star-to-delta)"
      }
    ]
  },
  "gate": {
    "checks": [
