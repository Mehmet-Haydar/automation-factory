        "name": "in_bEnable",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bReset",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bManualMode",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bStartCmd",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bStopCmd",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bManualStart",
        "iec_type": "Bool",
        "default": false,
        "required": true,
        "description": "Manual start (active only when in_bManualMode=TRUE)"
      },
      {
        "name": "in_bManualStop",
        "iec_type": "Bool",
        "default": false,
        "required": true,
        "description": "Manual stop (active only when in_bManualMode=TRUE)"
      },
      {
