        "description": "FB name is FB_MOTOR_VFD",
        "check_pattern": "FUNCTION_BLOCK\\s+\"?FB_MOTOR_VFD\"?",
        "severity": "MUST"
      },
      {
        "id": "B-VFD-011",
        "description": "Optimized Access declared",
        "check_pattern": "S7_Optimized_Access\\s*:=\\s*'TRUE'",
        "severity": "MUST"
      }
    ],
    "forbidden_patterns": [
