{
  "_schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "block": {
    "name": "FB_WATCHDOG",
    "version": "1.0.0",
    "type": "FB",
    "domain": "system",
    "device_type": "Watchdog",
    "platform": "S7_1500_TIA_V18+",
    "source": "Factory",
    "lifecycle": "DRAFT",
    "description": "Software watchdog. Detects missed heartbeats, OB1 cycle overruns, and communication loss. Triggers fault output and latches until manual reset."
  },
  "interface": {
    "inputs": [
      {
        "name": "in_bEnable",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bReset",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bHeartbeat",
        "iec_type": "Bool",
        "default": false,
        "required": true,
        "description": "Toggling signal from monitored source"
      },
      {
        "name": "in_tTimeout",
        "iec_type": "Time",
        "default": "T#1S",
        "required": true
      },
      {
        "name": "in_bMonitorComms",
        "iec_type": "Bool",
        "default": false,
        "required": true,
        "description": "Enable communication loss monitoring"
      }
    ],
    "outputs": [
      {
        "name": "out_bAlive",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bFault",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_wErrorCode",
        "iec_type": "Word",
        "default": "16#0000",
        "required": true
      },
      {
        "name": "out_nState",
        "iec_type": "Int",
        "default": 0,
        "required": true
      },
      {
        "name": "out_dTimeoutCount",
        "iec_type": "DInt",
        "default": 0,
        "required": true
      }
    ],
    "in_out": [],
    "static_vars": [
      {
        "name": "s_bResetEdgeMem",
        "iec_type": "Bool"
      },
      {
        "name": "s_bResetTrig",
        "iec_type": "Bool"
      },
      {
        "name": "s_bHeartbeatLastMem",
        "iec_type": "Bool"
      },
      {
        "name": "s_nStep",
        "iec_type": "Int"
      },
      {
        "name": "s_tonTimeout",
        "iec_type": "TON"
      }
    ]
  },
  "constraints": {
    "mandatory_regions": [
      "01_INPUT_VALIDATION",
      "02_STATE_MACHINE",
      "03_OUTPUT_LOGIC",
      "04_DIAGNOSTICS"
    ],
    "mandatory_behaviors": [
      {
        "id": "B-WD-001",
        "description": "Reset rising edge",
        "check_pattern": "s_bResetTrig\\s*:=\\s*.*in_bReset.*AND\\s*NOT.*s_bResetEdgeMem",
        "severity": "MUST"
      },
      {
        "id": "B-WD-002",
        "description": "Heartbeat edge detection present",
        "check_pattern": "s_bHeartbeatLastMem|HeartbeatMem|heartbeat.*edge|edge.*heartbeat",
        "severity": "MUST"
      },
      {
        "id": "B-WD-003",
        "description": "Timeout timer present",
        "check_pattern": "s_tonTimeout|tonTimeout",
        "severity": "MUST"
      },
      {
        "id": "B-WD-004",
        "description": "Fault latches until reset",
        "check_pattern": "out_bFault|Fault|FAULT",
        "severity": "MUST"
      },
      {
        "id": "B-WD-005",
        "description": "Error code 16#0001 present",
        "check_pattern": "16#0001",
        "severity": "MUST"
      },
      {
        "id": "B-WD-006",
        "description": "FB name is FB_WATCHDOG",
        "check_pattern": "FUNCTION_BLOCK\\s+\"?FB_WATCHDOG\"?",
        "severity": "MUST"
      },
      {
        "id": "B-WD-007",
        "description": "Optimized Access declared",
        "check_pattern": "S7_Optimized_Access\\s*:=\\s*'TRUE'",
        "severity": "MUST"
      }
    ],
    "forbidden_patterns": [
      "CURRENT_TIME\\(\\)",
      "GET_SYSTIME\\(\\)"
    ],
    "error_codes": [
      {
        "hex": "16#0001",
        "meaning": "Heartbeat timeout — monitored source stopped responding"
      },
      {
        "hex": "16#0002",
        "meaning": "Communication loss detected",
        "applies_to": [
          "with_comms_monitoring"
        ],
        "note": "Implement when in_bMonitorComms is wired — left as placeholder in base block"
      }
    ]
  },
  "gate": {
    "checks": [
      {
        "id": "G-01",
        "type": "structural",
        "description": "Structural balance",
        "required": true
      },
      {
        "id": "G-02",
        "type": "contract_interface",
        "description": "Required ports",
        "required": true
      },
      {
        "id": "G-03",
        "type": "contract_behavior",
        "description": "MUST behaviors",
        "required": true
      },
      {
        "id": "G-04",
        "type": "contract_error_codes",
        "description": "Error codes in SCL",
        "required": true
      },
      {
        "id": "G-05",
        "type": "forbidden_pattern",
        "description": "No proprietary calls",
        "required": true
      },
      {
        "id": "G-06",
        "type": "plcrex",
        "description": "PLCreX optional",
        "required": false
      }
    ]
  },
  "prompt_binding": {
    "file": "04_AI_PROMPTS/code_gen/system/PROMPT_SYSTEM_WATCHDOG.md",
    "version": "1.0.0",
    "last_synced": "2026-05-30"
  },
  "duplicate_detection": {
    "alternatives": [],
    "note": "Use for HMI/SCADA comms watchdog, OPC-UA client heartbeat, or inter-CPU monitoring."
  },
  "meta": {
    "source": "factory",
    "license": "MIT",
    "safety_class": "STANDARD",
    "target_platform": "TIA Portal V18+",
    "compatible_tia": [
      "V18",
      "V19"
    ]
  },
  "behaviors": [],
  "acceptance": {
    "contract_check": true,
    "compile_check": true,
    "sim_test": true,
    "human_signoff": true
  }
}