      },
      {
        "name": "s_nModeLast",
        "iec_type": "Int"
      }
    ]
  },
  "constraints": {
    "mandatory_regions": [
      "01_INPUT_VALIDATION",
      "02_STATE_MACHINE",
      "03_OUTPUT_LOGIC",
      "04_DIAGNOSTICS"
    ],
    "mandatory_behaviors": [
      {
        "id": "B-MM-001",
        "description": "Reset rising edge",
        "check_pattern": "s_bResetTrig\\s*:=\\s*.*in_bReset.*AND\\s*NOT.*s_bResetEdgeMem",
        "severity": "MUST"
      },
      {
        "id": "B-MM-002",
        "description": "Emergency takes priority (highest priority command)",
        "check_pattern": "in_bEmergency|Emergency|EMERGENCY",
        "severity": "MUST"
      },
      {
        "id": "B-MM-003",
        "description": "Exactly one mode output active at a time",
        "check_pattern": "out_bModeStop|out_bModeRunning|out_bModeHeld|out_bModeEmergency",
        "severity": "MUST"
      },
      {
        "id": "B-MM-004",
        "description": "Current mode number output updated",
        "check_pattern": "out_nCurrentMode",
        "severity": "MUST"
      },
      {
        "id": "B-MM-005",
        "description": "Error code 16#0001 present",
        "check_pattern": "16#0001",
        "severity": "MUST"
      },
      {
        "id": "B-MM-006",
        "description": "FB name is FB_ModeManager",
        "check_pattern": "FUNCTION_BLOCK\\s+\"?FB_ModeManager\"?",
        "severity": "MUST"
      },
      {
        "id": "B-MM-007",
        "description": "Optimized Access declared",
        "check_pattern": "S7_Optimized_Access\\s*:=\\s*'TRUE'",
        "severity": "MUST"
      }
    ],
    "forbidden_patterns": [
      "CURRENT_TIME\\(\\)",
      "GET_SYSTIME\\(\\)"
    ],
    "error_codes": [
      {
        "hex": "16#0001",
        "meaning": "Invalid mode transition requested (not allowed from current state)"
      },
      {
        "hex": "16#0002",
        "meaning": "Multiple conflicting commands active simultaneously"
      }
    ]
  },
