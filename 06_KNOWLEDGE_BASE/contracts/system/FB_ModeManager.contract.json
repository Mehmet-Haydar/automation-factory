{
  "_schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "block": {
    "name": "FB_ModeManager",
    "version": "1.0.0",
    "type": "FB",
    "domain": "system",
    "device_type": "ModeManager",
    "platform": "S7_1500_TIA_V18+",
    "source": "Factory",
    "lifecycle": "DRAFT",
    "description": "OMAC PackML mode manager. Manages transitions between modes (M00 Emergency, M01 Stopped, M02 Running, M03 Complete, M04 Suspended, M05 Held, M06 Idle). One mode active at a time."
  },
  "interface": {
    "inputs": [
