        "required": true
      },
      {
        "name": "out_wErrorCode",
        "iec_type": "Word",
        "default": "16#0000",
        "required": true
      },
      {
        "name": "out_nState",
        "iec_type": "Int",
        "default": 0,
        "required": true
      }
    ],
    "in_out": [],
    "static_vars": [
      {
        "name": "s_bResetEdgeMem",
        "iec_type": "Bool"
      },
      {
        "name": "s_bResetTrig",
