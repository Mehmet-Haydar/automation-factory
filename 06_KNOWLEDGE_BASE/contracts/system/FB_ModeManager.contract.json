      },
      {
        "name": "in_bEmergency",
        "iec_type": "Bool",
        "default": false,
        "required": true
      }
    ],
    "outputs": [
      {
        "name": "out_nCurrentMode",
        "iec_type": "Int",
        "default": 0,
        "required": true,
        "description": "Current mode number (OMAC PackML)"
      },
      {
        "name": "out_bModeStop",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bModeRunning",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bModeHeld",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "out_bModeEmergency",
