        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bCmdHold",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bCmdUnhold",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bCmdSuspend",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bCmdUnsuspend",
        "iec_type": "Bool",
        "default": false,
        "required": true
      },
      {
        "name": "in_bCmdAbort",
