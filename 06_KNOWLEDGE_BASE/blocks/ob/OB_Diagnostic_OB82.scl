ORGANIZATION_BLOCK "OB_DIAGNOSTIC_OB82"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0

   VAR_TEMP
      tmp_wDiagData : Word;   // Diagnostic data placeholder
   END_VAR


BEGIN

   //===========================================================================
   // REGION: 01_READ_DIAG
   // Purpose: Read diagnostic data from the event
   //===========================================================================
   REGION 01_READ_DIAG
      // <PROJECT_READ_DIAG> — start-info skeleton (project-adapt VAR_TEMP names)
      // TIA Portal exposes these as OB local variables in VAR_TEMP:
      //   OB82_MDL_ADDR  : Word;    // Module I/O address with fault
      //   OB82_EV_CLASS  : Byte;    // Event class (16#38 = going, 16#39 = coming)
      //   OB82_FLT_REG   : Byte;    // Module fault register
      //   OB82_MDL_DEFECT: Bool;    // TRUE when module defective
      // Example read (adapt tag/DB names):
      //   tmp_wDiagData := OB82_MDL_ADDR;
      //   IF OB82_MDL_DEFECT THEN ... END_IF;
   END_REGION


   //===========================================================================
   // REGION: 02_SET_ALARM
   // Purpose: Set the appropriate alarm flag based on diagnostic event
   //===========================================================================
   REGION 02_SET_ALARM
      // <PROJECT_SET_ALARM>
      // Set alarm flag in DB_Diagnostics based on failing module address
      // Example: "DB_Diagnostics".bModuleFault := TRUE;
   END_REGION


   //===========================================================================
   // REGION: 03_LOG_EVENT
   // Purpose: Log the diagnostic event to the system event buffer
   //===========================================================================
   REGION 03_LOG_EVENT
      // <PROJECT_LOG_EVENT>
      // Increment diagnostic event counter, store timestamp
   END_REGION


END_ORGANIZATION_BLOCK
