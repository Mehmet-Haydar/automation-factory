// FB_Motor_SoftStarter — Soft-Starter Motor Control
// Source    : Factory Library
// Contract  : 06_KNOWLEDGE_BASE/contracts/motor/FB_Motor_SoftStarter.contract.json
// Lifecycle : AUTO_VERIFIED_structural | PENDING_TIA_VERIFY
