{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rd04_mode.schema.json",
  "title": "RD04 — Operating Modes",
  "description": "Per-project operating modes. Spec: MDSCHEMA_RAWDATA_04_MODE.md",
  "type": "object",
  "required": ["project_id", "Modes"],
  "properties": {
    "project_id": { "type": "string" },
    "Modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ModeID", "ModeName", "Priority", "PackMLState", "Description", "EntryCondition", "ExitCondition", "PermittedActions", "HMI_Color", "HMI_Text", "DB_ModeWord", "Status"],
        "properties": {
          "ModeID": { "type": "string", "pattern": "^M\\d{2}$" },
          "ModeName": { "type": "string", "minLength": 1 },
          "Priority": { "type": "integer", "minimum": 0, "maximum": 99 },
          "PackMLState": {
            "type": "string",
            "enum": ["Idle", "Starting", "Execute", "Completing", "Complete", "Resetting", "Held", "Holding", "Suspended", "Suspending", "Unsuspending", "Unholding", "Stopped", "Stopping", "Aborted", "Aborting", "Clearing"]
          },
          "Description": { "type": "string" },
          "EntryCondition": { "type": "string", "minLength": 1 },
          "ExitCondition": { "type": "string", "minLength": 1 },
          "PermittedActions": { "type": "string" },
          "RestrictedActions": { "type": "string" },
          "HMI_Color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "HMI_Text": { "type": "string", "minLength": 1 },
          "DB_ModeWord": { "type": "string", "minLength": 1 },
          "Notes": { "type": "string" },
          "Status": { "type": "string", "enum": ["Active", "Inactive", "Spare"] }
        },
        "allOf": [
          {
            "if": { "properties": { "ModeID": { "const": "M00" } } },
            "then": { "properties": { "Priority": { "const": 0 } } }
          }
        ],
        "additionalProperties": true
      },
      "uniqueItemProperties": ["Priority"]
    }
  }
}
