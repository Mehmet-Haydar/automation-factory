{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rd02_datadict.schema.json",
  "title": "RD02 — Data Dictionary",
  "description": "Per-project data dictionary. Spec: MDSCHEMA_RAWDATA_02_DATADICT.md",
  "type": "object",
  "required": ["project_id", "Variables"],
  "properties": {
    "project_id": { "type": "string" },
    "filled_by": { "type": "string" },
    "filled_at": { "type": "string", "format": "date" },
    "Variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "VarName", "Scope", "ParentBlock", "Type",
          "Description", "Status"
        ],
        "properties": {
          "VarName": {
            "type": "string",
            "minLength": 1
          },
          "Scope": {
            "type": "string",
            "enum": ["GlobalDB", "InstanceDB", "UDT", "MemoryMarker", "TempVar"]
          },
          "ParentBlock": { "type": "string", "minLength": 1 },
          "Type": {
            "type": "string",
            "pattern": "^(BOOL|BYTE|WORD|DWORD|LWORD|SINT|INT|DINT|LINT|USINT|UINT|UDINT|ULINT|REAL|LREAL|TIME|DATE|TIME_OF_DAY|DATE_AND_TIME|STRING|WSTRING|ARRAY|STRUCT|UDT_[A-Za-z0-9_]+)$"
          },
          "Offset": { "type": ["string", "number"] },
          "InitValue": { "type": ["string", "number", "boolean"] },
          "Retain": {
            "type": "string",
            "enum": ["Y", "N", "N/A"]
          },
          "Description": { "type": "string", "minLength": 1 },
          "LinkedTag": { "type": "string" },
          "OldVar": { "type": "string" },
          "Notes": { "type": "string" },
          "Status": {
            "type": "string",
            "enum": ["Active", "Inactive", "Spare"]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "Scope": { "enum": ["MemoryMarker", "TempVar"] } }
            },
            "then": {
              "properties": {
                "Retain": { "const": "N/A" }
              }
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "Unknowns": { "type": "array" }
  }
}
