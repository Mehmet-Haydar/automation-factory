{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rd09_comms.schema.json",
  "title": "RD09 — Communications",
  "description": "Per-project communications. Spec: MDSCHEMA_RAWDATA_09_COMMS.md",
  "type": "object",
  "required": ["project_id", "Connections"],
  "properties": {
    "project_id": { "type": "string" },
    "Connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["CommID", "Protocol", "LocalDevice", "RemoteDevice", "Direction", "Status"],
        "properties": {
          "CommID": { "type": "string", "pattern": "^COM\\d{3}$" },
          "Protocol": {
            "type": "string",
            "enum": ["PROFINET", "PROFIBUS_DP", "Modbus_RTU", "Modbus_TCP", "EtherNet_IP", "EtherCAT", "OPC_UA", "S7_Comm", "IO_Link", "AS_Interface", "Other"]
          },
          "LocalDevice": { "type": "string" },
          "RemoteDevice": { "type": "string" },
          "RemoteIP": { "type": "string", "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}$|^$" },
          "RemoteAddress": { "type": ["string", "number"] },
          "Direction": { "type": "string", "enum": ["TX", "RX", "Bidirectional"] },
          "TxByteCount": { "type": ["integer", "string"] },
          "RxByteCount": { "type": ["integer", "string"] },
          "CycleTime_ms": { "type": ["number", "string"] },
          "WatchdogTime_ms": { "type": ["number", "string"] },
          "DataBlock_TX": { "type": "string" },
          "DataBlock_RX": { "type": "string" },
          "ErrorTag": { "type": "string" },
          "Notes": { "type": "string" },
          "Status": { "type": "string", "enum": ["Active", "Inactive", "Spare"] }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "Protocol": {
                  "enum": ["PROFINET", "Modbus_TCP", "EtherNet_IP", "EtherCAT", "OPC_UA", "S7_Comm"]
                }
              }
            },
            "then": {
              "required": ["RemoteIP"],
              "properties": {
                "RemoteIP": { "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}$" }
              }
            }
          }
        ],
        "additionalProperties": true
      }
    }
  }
}
