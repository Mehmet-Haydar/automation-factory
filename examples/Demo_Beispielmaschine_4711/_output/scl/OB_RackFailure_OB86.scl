ORGANIZATION_BLOCK "OB_RackFailure_OB86"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0

   VAR_TEMP
      tmp_wStationAddr : Word;   // Failing station address
   END_VAR


BEGIN

   //===========================================================================
   // REGION: 01_READ_EVENT
   // Purpose: Read the rack/DP failure event data
   //===========================================================================
   REGION 01_READ_EVENT
      // <PROJECT_READ_EVENT> — start-info skeleton (project-adapt VAR_TEMP names)
      // TIA Portal exposes these as OB local variables in VAR_TEMP:
      //   OB86_MDL_ADDR : Word;   // Failing station I/O address
      //   OB86_EV_CLASS : Byte;   // 16#38 = coming (failure), 16#39 = going (recovery)
      // Example read:
      //   tmp_wStationAddr := OB86_MDL_ADDR;
   END_REGION


   //===========================================================================
   // REGION: 02_SET_COMMS_FAULT
   // Purpose: Set global communication fault flag in system DB
   //===========================================================================
   REGION 02_SET_COMMS_FAULT
      // <PROJECT_SET_COMMS_FAULT>
      // Example: "DB_System".bCommsFault := TRUE;
      //          "DB_System".wFaultStation := tmp_wStationAddr;
   END_REGION


   //===========================================================================
   // REGION: 03_LOG_STATION
   // Purpose: Log the failing station to the diagnostic buffer
   //===========================================================================
   REGION 03_LOG_STATION
      // <PROJECT_LOG_STATION>
      // Increment comms fault counter, store station address and event class
   END_REGION


END_ORGANIZATION_BLOCK
